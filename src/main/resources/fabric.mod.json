{
  "schemaVersion": 1,
  "id": "conduit",
  "version": "${version}",
  "name": "Conduit",
  "description": "Automatic server-to-client mod synchronization with hash verification.",
  "authors": ["Jacob0225"],
  "contact": {
    "sources": "https://github.com/jacob0225/conduit"
  },
  "license": "All-Rights-Reserved",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.jacob0225.conduit.Conduit"
    ],
    "client": [
      "com.jacob0225.conduit.client.ConduitClient"
    ]
  },
  "mixins": [
    {
      "config": "conduit.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": "*",
    "fabric-api": "*",
    "minecraft": "*"
  }
}
